{
  "name": "aura-console",
  "version": "1.0.0",
  "description": "Aura Console - Dashboard for ROM Downloading & Emulation",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.auraconsole.app",
    "productName": "Aura Console",
    "files": [
      "electron-main.js",
      "downloader/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      },
      "compat_db.json"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.games",
      "identity": null
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
